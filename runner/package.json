{
  "name": "sdd-worker",
  "version": "0.2.1",
  "type": "module",
  "bin": {
    "sdd-worker": "dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "npm run build && cd dist && node --test",
    "copy-assets": "node scripts/copy-assets.mjs",
    "prepack": "npm run copy-assets && npm run build",
    "prepublishOnly": "npm run check && npm test"
  },
  "files": [
    "dist",
    "assets",
    "README.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/kakeru-ikeda/claude-worker-sdd.git",
    "directory": "runner"
  },
  "description": "Superpowers-centered SDD workflow runner for task-scoped worker delegation",
  "keywords": [
    "sdd",
    "claude-code",
    "codex",
    "opencode",
    "workflow",
    "orchestration"
  ],
  "dependencies": {
    "@inquirer/prompts": "^8.5.2",
    "cross-spawn": "^7.0.6",
    "yaml": "^2.8.1"
  },
  "devDependencies": {
    "@types/cross-spawn": "^6.0.6",
    "@types/node": "^24.0.0",
    "typescript": "^5.8.0"
  }
}
